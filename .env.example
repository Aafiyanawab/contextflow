# Copy to .env and fill in. Values here document every setting the app reads.
# docker-compose substitutes the secrets below into the web container; the
# DATABASE_URL / S3_* values are set by compose itself for local runs.

# ---- Required ----
SECRET_KEY=            # long random string; app refuses to boot without it
                       #   python -c "import secrets; print(secrets.token_hex(32))"
OPENAI_API_KEY=        # chat + embeddings
GITHUB_TOKEN=          # repository scanning

# ---- Login providers (optional; shown only when configured) ----
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=


# ---- Database ----
# Unset -> dev SQLite. Set -> Postgres (compose and production set this).
#   postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=

# ---- File storage (the AWS seam) ----
# Unset S3_BUCKET -> local disk. Set -> S3 (or MinIO with S3_ENDPOINT_URL).
# S3_BUCKET=contextflow-uploads
# S3_ENDPOINT_URL=          # set for MinIO; leave UNSET for real AWS S3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=        # on EC2/EKS, prefer an instance role over keys
# AWS_SECRET_ACCESS_KEY=

# ---- Password reset email (optional) ----
# Unset SMTP_HOST -> reset links are logged, not emailed (dev). Set -> real send.
# APP_BASE_URL=https://your-domain.example   # absolute base for links in emails (prod endpoint)
# SMTP_HOST=smtp.gmail.com                    # set to enable sending
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=                              # Gmail App Password (16 chars) — never commit
# SMTP_FROM=ContextFlow <you@example.com>

# ---- Runtime (optional) ----
# WEB_WORKERS=1             # gunicorn processes (keep at 1 until rate limits move to Redis)
# WEB_THREADS=8             # threads per worker
# FLASK_ENV=production      # enables Secure cookies
